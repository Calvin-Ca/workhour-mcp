# 网关共享令牌 —— 客户端 X-Gateway-Token 必须与之相等。
# 生成强随机值： openssl rand -hex 32
MCP_GATEWAY_TOKEN=change-me-openssl-rand-hex-32

# 后端 ai-service 地址。
# - 本地演示/评审：留默认，走同 compose 的 mock-ai-service。
# - 生产：指向真实 ai-service，例如 http://ai-service:8000
AI_SERVICE_URL=http://mock-ai-service:8000

# Service Account 换 JWT 用的 api_key（沙箱可留空；生产按后端约定填）。
MCP_API_KEY=

# 每 entity_id 的身份缓存 TTL（秒）。
MCP_GATEWAY_TOKEN_TTL=1500
